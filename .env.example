# ===========================================
# SSM E-Commerce - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# Database Connection (PostgreSQL via Neon)
# Get your URL from https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Paystack Payment Gateway
# Get your API keys from https://dashboard.paystack.com/#/settings/developers
# Use sk_test_/pk_test_ for testing, sk_live_/pk_live_ for production
PAYSTACK_SECRET_KEY=sk_test_REPLACE_ME
PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_ME

# App URL
# Set to your production URL when deploying
NEXT_PUBLIC_URL=https://samassumamart.co.ke

# Paystack public key exposed to the browser (must match PAYSTACK_PUBLIC_KEY)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_ME
